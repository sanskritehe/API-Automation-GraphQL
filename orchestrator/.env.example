# ── Jira ──────────────────────────────────────────────────────────────
JIRA_DOMAIN=https://your-org.atlassian.net
JIRA_EMAIL=your-email@example.com
JIRA_API_TOKEN=<jira-api-token>

# ── Confluence ────────────────────────────────────────────────────────
CONFLUENCE_DOMAIN=https://your-org.atlassian.net
CONFLUENCE_EMAIL=your-email@example.com
CONFLUENCE_API_TOKEN=<confluence-api-token>

# ── GitHub ────────────────────────────────────────────────────────────
GITHUB_TOKEN=<github-pat>
GITHUB_OWNER=<github-username-or-org>

# ── GitHub Copilot SDK ────────────────────────────────────────────────
# Token needs "Copilot Requests" permission.
# Remove or leave blank to fall back to local `gh auth` credentials.
COPILOT_GITHUB_TOKEN=<github-pat-with-copilot-permission>

# ── GitHub Copilot Models (via GitHub Models API) ─────────────────────
GENERATOR_MODEL=gpt-4o
JUDGE_MODEL=gpt-4o
